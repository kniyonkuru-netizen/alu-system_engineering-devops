#!/usr/bin/env bash
# Configures nginx (from scratch on a brand new Ubuntu machine) so that
# /redirect_me returns a 301 Moved Permanently redirect, and the root page
# still returns "Holberton School".

apt-get update -y
apt-get install -y nginx

echo "Holberton School for the win!" > /var/www/html/index.nginx-debian.html

CONFIG_FILE="/etc/nginx/sites-available/default"

# Remove any pre-existing redirect_me rule to keep this script idempotent
sed -i "/redirect_me/,+2d" "$CONFIG_FILE"

# Insert the redirect rule right after the "server_name" line, using sed
sed -i "/server_name _;/a\\
\\trewrite ^/redirect_me/?$ https://www.youtube.com/watch?v=QH2-TGUlwu4 permanent;" "$CONFIG_FILE"

service nginx restart || /etc/init.d/nginx restart
