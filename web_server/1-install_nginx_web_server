#!/usr/bin/env bash
# Installs and configures nginx so that a GET request to / returns a page
# containing the string "Holberton School". Restarts nginx without systemctl.

apt-get update -y
apt-get install -y nginx

echo "Holberton School for the win!" > /var/www/html/index.nginx-debian.html

# Make sure nginx listens on port 80 (default) and is enabled
service nginx restart || /etc/init.d/nginx restart
