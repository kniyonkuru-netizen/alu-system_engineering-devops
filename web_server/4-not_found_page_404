#!/usr/bin/env bash
# Configures nginx (from scratch on a brand new Ubuntu machine) with:
#   - / returning "Holberton School"
#   - /redirect_me returning a 301 redirect
#   - a custom 404 page containing "Ceci n'est pas une page"

apt-get update -y
apt-get install -y nginx

echo "Holberton School for the win!" > /var/www/html/index.nginx-debian.html
echo "Ceci n'est pas une page" > /var/www/html/404.html

CONFIG_FILE="/etc/nginx/sites-available/default"

# Redirect rule (idempotent)
sed -i "/redirect_me/,+2d" "$CONFIG_FILE"
sed -i "/server_name _;/a\\
\\trewrite ^/redirect_me/?$ https://www.youtube.com/watch?v=QH2-TGUlwu4 permanent;" "$CONFIG_FILE"

# Custom 404 error page (idempotent)
sed -i "/error_page 404/d" "$CONFIG_FILE"
sed -i "/server_name _;/a\\
\\terror_page 404 /404.html;" "$CONFIG_FILE"

service nginx restart || /etc/init.d/nginx restart
